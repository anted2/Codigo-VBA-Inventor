' =============================================================================
' BOTÓN PRINCIPAL - Generar BOM Multinivel
' =============================================================================
Private Sub btnBOM_Click()
    On Error GoTo ErrorHandler
    
    MsgBox "Generando BOM Multinivel...", vbInformation
    DoEvents
    
    Const carpetaPath As String = "C:\Users\User\OneDrive - Dinamo Ingenieria SpA\Documents\Soporte Richard\MCEN-SRA\"
    Const plantillaPath As String = "C:\Users\User\OneDrive - Dinamo Ingenieria SpA\Documents\Soporte Richard\MCEN-SRA\BOM_PLANTILLA.xlsx"
    
    Dim fso As Object
    Set fso = CreateObject("Scripting.FileSystemObject")
    
    If Not fso.FolderExists(carpetaPath) Then
        MsgBox "La carpeta no existe:" & vbCrLf & carpetaPath, vbCritical
        Exit Sub
    End If
    
    If Not fso.FileExists(plantillaPath) Then
        MsgBox "Plantilla no encontrada:" & vbCrLf & plantillaPath, vbCritical
        Exit Sub
    End If
    
    Dim nombreProyecto As String
    nombreProyecto = fso.GetFolder(carpetaPath).Name
    
    Dim ruta As String
    ruta = Environ$("USERPROFILE") & "\Desktop\BOM_" & nombreProyecto & "_" & _
           Format(Now, "yyyy-mm-dd_hh-mm-ss") & ".xlsx"
    
    fso.CopyFile plantillaPath, ruta
    
    Dim xlApp As Object
    Set xlApp = CreateObject("Excel.Application")
    xlApp.Visible = False
    
    Dim wb As Object
    Set wb = xlApp.Workbooks.Open(ruta)
    
    Dim ws As Object
    Set ws = wb.Sheets(1)
    ws.Cells.Clear
    
    EscribirEncabezadoTabla ws, nombreProyecto
    
    Dim carpeta As Object
    Set carpeta = fso.GetFolder(carpetaPath)
    
    Dim arch As Object
    Dim filaActual As Long: filaActual = 5
    Dim totalEnsambles As Long: totalEnsambles = 0
    
    For Each arch In carpeta.Files
        If LCase(fso.GetExtensionName(arch.Name)) <> "iam" Then GoTo SigArchivo
        
        Dim docAsm As Object
        Set docAsm = AbrirObtenerEnsamble(arch.Path)
        If docAsm Is Nothing Then GoTo SigArchivo
        
        totalEnsambles = totalEnsambles + 1
        
        Dim prefRaiz As String: prefRaiz = CStr(totalEnsambles)
        Dim nombreRaizLimpio As String: nombreRaizLimpio = fso.GetBaseName(arch.Name)
        
        ' Fila raíz - nivel 0
        EscribirFilaNivel ws, filaActual, prefRaiz, _
            nombreRaizLimpio, "", _
            1, "und", "Ensamble", 0, "", "", "", "", "", "", ""
        
        filaActual = filaActual + 1
        
        Dim contHijos(1 To 20) As Long
        Dim j As Integer
        For j = 1 To 20
            contHijos(j) = 0
        Next j
        
        Dim defRaiz As Object
        Set defRaiz = docAsm.ComponentDefinition
        
        If defRaiz Is Nothing Then
            MsgBox "ERROR: ComponentDefinition es Nothing para " & arch.Name, vbCritical
            GoTo SigArchivo
        End If
        
        RecorrerNivel ws, defRaiz, filaActual, prefRaiz, contHijos, 1
        filaActual = filaActual + 1
        
SigArchivo:
    Next arch
    
    ws.Columns("A").ColumnWidth = 10
    ws.Columns("B").ColumnWidth = 44
    ws.Columns("C").ColumnWidth = 28
    ws.Columns("D").ColumnWidth = 7
    ws.Columns("E").ColumnWidth = 16
    ws.Columns("F").ColumnWidth = 11
    ws.Columns("G").ColumnWidth = 11
    ws.Columns("H").ColumnWidth = 11
    ws.Columns("I").ColumnWidth = 13
    ws.Columns("J").ColumnWidth = 14
    ws.Columns("K").ColumnWidth = 16
    ws.Columns("L").ColumnWidth = 14
    
    wb.Save
    wb.Close False
    xlApp.Quit
    
    MsgBox "BOM generado exitosamente:" & vbCrLf & ruta, vbInformation, "Listo"
    Exit Sub

ErrorHandler:
    MsgBox "Error " & Err.Number & ": " & Err.Description & vbCrLf & vbCrLf & _
           "Último archivo: " & IIf(Not arch Is Nothing, arch.Name, "ninguno"), vbCritical
    
    On Error Resume Next
    If Not wb Is Nothing Then wb.Close False
    If Not xlApp Is Nothing Then xlApp.Quit
End Sub

' =============================================================================
' RECURSIÓN PRINCIPAL
'
' Reglas de jerarquía:
' - Cualquier .iam que NO empiece con "Ensamble_" se expande (recursión)
' - Cualquier .iam que empiece con "Ensamble_" TERMINAL: se lista
'   como fila única, su código = nombre sin el prefijo "Ensamble_",
'   NO se baja a sus hijos
' - Cualquier .ipt = Pieza, sin recursión
' =============================================================================
Private Sub RecorrerNivel(ByVal ws As Object, _
                          ByVal def As Object, _
                          ByRef fila As Long, _
                          ByVal prefijo As String, _
                          ByRef contadores() As Long, _
                          ByVal nivel As Integer)
    On Error GoTo ErrRec
    
    If def Is Nothing Then Exit Sub
    If nivel > 20 Then Exit Sub
    
    ' 1. Verificar que hay ocurrencias
    Dim occCount As Long: occCount = 0
    On Error Resume Next
    occCount = def.Occurrences.Count
    On Error GoTo ErrRec
    If occCount = 0 Then Exit Sub
    
    ' 2. Agrupar ocurrencias por DisplayName
    Dim dictCant As Object
    Set dictCant = CreateObject("Scripting.Dictionary")
    dictCant.CompareMode = 1
    
    Dim dictDef As Object
    Set dictDef = CreateObject("Scripting.Dictionary")
    dictDef.CompareMode = 1
    
    Dim occ As Object
    For Each occ In def.Occurrences
        On Error Resume Next
        
        Dim dispName As String: dispName = ""
        dispName = occ.Definition.Document.DisplayName
        
        Dim errNum As Long: errNum = Err.Number
        On Error GoTo ErrRec
        
        If errNum <> 0 Or Len(Trim(dispName)) = 0 Then GoTo SigOcc1
        
        If dictCant.Exists(dispName) Then
            dictCant(dispName) = dictCant(dispName) + 1
        Else
            dictCant.Add dispName, 1
            
            On Error Resume Next
            Dim defHijoTemp As Object
            Set defHijoTemp = occ.Definition
            If Err.Number = 0 And Not defHijoTemp Is Nothing Then
                dictDef.Add dispName, defHijoTemp
            End If
            Err.Clear
            On Error GoTo ErrRec
        End If
        
SigOcc1:
    Next occ
    
    If dictCant.Count = 0 Then Exit Sub
    
    ' 3. Iterar componentes únicos
    Dim k As Variant
    For Each k In dictCant.Keys
        contadores(nivel) = contadores(nivel) + 1
        
        Dim numItem As String
        numItem = prefijo & "." & contadores(nivel)
        
        Dim defHijo As Object
        Set defHijo = Nothing
        If dictDef.Exists(k) Then Set defHijo = dictDef(k)
        
        ' Detectar si es ensamble
        Dim esAsm As Boolean: esAsm = False
        If Not defHijo Is Nothing Then
            On Error Resume Next
            
            Dim tipoNum As Long: tipoNum = defHijo.Type
            If Err.Number = 0 Then esAsm = (tipoNum = 12291)
            
            If Err.Number <> 0 Or Not esAsm Then
                Dim tn As String: tn = TypeName(defHijo)
                esAsm = (InStr(LCase(tn), "assembly") > 0)
            End If
            
            Err.Clear
            On Error GoTo ErrRec
        End If
        
        ' Nombre limpio sin extensión
        Dim nombreLimpio As String: nombreLimpio = CStr(k)
        Dim posExt As Long: posExt = InStrRev(nombreLimpio, ".")
        If posExt > 0 Then nombreLimpio = Left(nombreLimpio, posExt - 1)
        
        ' Lógica central
        Dim esTerminal As Boolean
        esTerminal = (esAsm And LCase(Left(nombreLimpio, 9)) = "ensamble_")
        
        Dim tipoStr As String
        Dim codigoVal As String
        
        If esTerminal Then
            tipoStr = "Sub-ensamble"
            codigoVal = Mid(nombreLimpio, 10)
        ElseIf esAsm Then
            tipoStr = "Sub-ensamble"
            codigoVal = ""
        Else
            tipoStr = "Pieza"
            codigoVal = nombreLimpio
        End If
        
        ' Leer masa y propiedades custom
        Dim descVal As String: descVal = ""
        Dim largoVal As String: largoVal = ""
        Dim anchoVal As String: anchoVal = ""
        Dim altoVal As String: altoVal = ""
        Dim diametroVal As String: diametroVal = ""
        Dim pesoVal As String: pesoVal = "0"
        
        If Not defHijo Is Nothing Then
            On Error Resume Next
            
            Dim massKg As Double
            massKg = defHijo.MassProperties.Mass
            If Err.Number = 0 And massKg > 0.000001 Then
                pesoVal = Format(massKg, "0.0000")
            End If
            
            Err.Clear
            On Error GoTo ErrRec
            
            On Error Resume Next
            Dim props As Object
            Set props = Nothing
            Set props = defHijo.Document.PropertySets("Inventor User Defined Properties")
            Err.Clear
            
            If Not props Is Nothing Then
                Dim p As Object
                For Each p In props
                    On Error Resume Next
                    
                    Dim pName As String: pName = LCase(Trim(p.Name))
                    Dim pValue As String: pValue = CStr(p.Value)
                    Err.Clear
                    
                    Select Case pName
                        Case "descripcion": descVal = pValue
                        Case "largo": largoVal = pValue
                        Case "ancho": anchoVal = pValue
                        Case "alto": altoVal = pValue
                        Case "diametro": diametroVal = pValue
                    End Select
                Next p
            End If
            
            On Error GoTo ErrRec
        End If
        
        ' Normalizar dimensiones
        largoVal = RedondearStr(largoVal)
        anchoVal = RedondearStr(anchoVal)
        altoVal = RedondearStr(altoVal)
        diametroVal = RedondearStr(diametroVal)
        
        ' Descripción por defecto
        If Len(Trim(descVal)) = 0 Then
            If esTerminal Then
                descVal = codigoVal
            Else
                descVal = nombreLimpio
            End If
        End If
        
        ' Cantidad y peso total
        Dim cantNum As Long: cantNum = CLng(dictCant(k))
        Dim pesoTotal As String: pesoTotal = ""
        
        If pesoVal <> "0" And Len(Trim(pesoVal)) > 0 Then
            On Error Resume Next
            
            Dim pesoNum As Double: pesoNum = CDbl(pesoVal)
            If Err.Number = 0 And pesoNum > 0 Then
                pesoTotal = Format(pesoNum * cantNum, "0.00")
            End If
            
            Err.Clear
            On Error GoTo ErrRec
        End If
        
        ' Escribir fila
        EscribirFilaNivel ws, fila, numItem, descVal, codigoVal, _
            cantNum, "und", tipoStr, nivel, _
            largoVal, anchoVal, altoVal, diametroVal, "", pesoVal, pesoTotal
        
        fila = fila + 1
        
        ' Recursión SOLO si es ensamble NO terminal
        If esAsm And Not esTerminal And Not defHijo Is Nothing Then
            Dim m As Integer
            For m = nivel + 1 To 20
                contadores(m) = 0
            Next m
            
            RecorrerNivel ws, defHijo, fila, numItem, contadores, nivel + 1
        End If
    Next k
    
    Exit Sub

ErrRec:
    MsgBox "ERROR RecorrerNivel" & vbCrLf & _
           "Nivel: " & nivel & " | Prefijo: " & prefijo & vbCrLf & _
           "Error " & Err.Number & ": " & Err.Description, vbCritical
    Resume Next
End Sub

' =============================================================================
' ESCRIBIR FILA - 12 columnas
' =============================================================================
Private Sub EscribirFilaNivel(ByVal ws As Object, _
                              ByVal fila As Long, _
                              ByVal numItem As String, _
                              ByVal descripcion As String, _
                              ByVal codigo As String, _
                              ByVal cantidad As Long, _
                              ByVal unidad As String, _
                              ByVal tipo As String, _
                              ByVal nivel As Integer, _
                              ByVal largo As String, _
                              ByVal ancho As String, _
                              ByVal alto As String, _
                              ByVal diametro As String, _
                              ByVal codigoSKU As String, _
                              ByVal pesoUnit As String, _
                              ByVal pesoTotal As String)
    On Error GoTo ErrFila
    
    Dim bgColor As Long
    Dim fgColor As Long
    Dim boldFont As Boolean
    Dim fontSize As Integer
    Dim indent As String
    
    Select Case nivel
        Case 0
            bgColor = RGB(47, 117, 182)
            fgColor = RGB(255, 255, 255)
            boldFont = True
            fontSize = 11
            indent = "> "
        Case 1
            bgColor = RGB(189, 215, 238)
            fgColor = RGB(31, 56, 100)
            boldFont = True
            fontSize = 10
            indent = " >> "
        Case 2
            bgColor = RGB(221, 235, 247)
            fgColor = RGB(31, 56, 100)
            boldFont = True
            fontSize = 10
            indent = " >> "
        Case Else
            If fila Mod 2 = 0 Then
                bgColor = RGB(255, 255, 255)
            Else
                bgColor = RGB(242, 247, 252)
            End If
            fgColor = RGB(31, 32, 32)
            boldFont = False
            fontSize = 10
            indent = Space((nivel - 1) * 4) & "- "
    End Select
    
    Dim vals(1 To 12) As Variant
    vals(1) = numItem
    vals(2) = indent & descripcion
    vals(3) = codigo
    vals(4) = cantidad
    vals(5) = unidad
    vals(6) = largo
    vals(7) = ancho
    vals(8) = alto
    vals(9) = diametro
    vals(10) = codigoSKU
    vals(11) = pesoUnit
    vals(12) = pesoTotal
    
    Dim col As Integer
    For col = 1 To 12
        Dim cel As Object
        Set cel = ws.Cells(fila, col)
        
        cel.Value = vals(col)
        cel.Interior.Color = bgColor
        cel.Font.Color = fgColor
        cel.Font.Bold = boldFont
        cel.Font.Size = fontSize
        cel.Font.Name = "Arial"
        cel.VerticalAlignment = -4108
        
        If col = 4 Then
            cel.HorizontalAlignment = -4108
        Else
            cel.HorizontalAlignment = -4131
        End If
        
        Dim b As Integer
        For b = 7 To 10
            cel.Borders(b).LineStyle = 1
            cel.Borders(b).Color = RGB(157, 195, 230)
        Next b
    Next col
    
    If nivel = 0 Then
        Dim rng As Object
        Set rng = ws.Range(ws.Cells(fila, 1), ws.Cells(fila, 12))
        
        For b = 7 To 10
            rng.Borders(b).Weight = 3
            rng.Borders(b).Color = RGB(31, 56, 100)
        Next b
    End If
    
    ws.Rows(fila).RowHeight = 18
    Exit Sub

ErrFila:
    MsgBox "ERROR EscribirFilaNivel - Fila:" & fila & " Nivel:" & nivel & _
           " Codigo:" & codigo & vbCrLf & _
           Err.Number & " - " & Err.Description, vbCritical
    Resume Next
End Sub

' =============================================================================
' ENCABEZADO - Filas 1-4, 12 columnas
' =============================================================================
Private Sub EscribirEncabezadoTabla(ByVal ws As Object, ByVal nombreProyecto As String)
    On Error GoTo ErrEncabezado
    
    ws.Rows(1).RowHeight = 36
    ws.Range("A1:L1").Merge
    With ws.Range("A1")
        .Value = "BILL OF MATERIALS - " & UCase(nombreProyecto)
        .Font.Name = "Arial"
        .Font.Bold = True
        .Font.Size = 16
        .Font.Color = RGB(255, 255, 255)
        .Interior.Color = RGB(31, 56, 100)
        .HorizontalAlignment = -4108
        .VerticalAlignment = -4108
    End With
    
    ws.Rows(2).RowHeight = 18
    ws.Range("A2:L2").Merge
    With ws.Range("A2")
        .Value = "Generado: " & Format(Now, "yyyy-mm-dd hh:nn:ss") & _
                 " | Proyecto: " & nombreProyecto
        .Font.Name = "Arial"
        .Font.Size = 9
        .Font.Italic = True
        .Font.Color = RGB(100, 100, 100)
        .Interior.Color = RGB(240, 244, 250)
        .HorizontalAlignment = -4108
    End With
    
    ws.Rows(3).RowHeight = 6
    ws.Rows(4).RowHeight = 22
    
    Dim headers As Variant
    headers = Array("Item", "Descripcion", "Codigo", "Cant.", _
                    "Unidad de Cotizacion", "Largo (mm)", "Ancho (mm)", _
                    "Alto (mm)", "Diametro (mm)", "Codigo SKU", _
                    "Peso Unitario (Kg)", "Peso Total (Kg)")
    
    Dim ci As Integer
    For ci = 0 To 11
        With ws.Cells(4, ci + 1)
            .Value = headers(ci)
            .Font.Name = "Arial"
            .Font.Bold = True
            .Font.Size = 10
            .Font.Color = RGB(255, 255, 255)
            .Interior.Color = RGB(31, 56, 100)
            .HorizontalAlignment = -4108
            .VerticalAlignment = -4108
        End With
    Next ci
    
    Exit Sub

ErrEncabezado:
    MsgBox "ERROR EscribirEncabezadoTabla" & vbCrLf & _
           Err.Number & " - " & Err.Description, vbCritical
    Resume Next
End Sub

' =============================================================================
' HELPER: redondear string numérico a entero (maneja coma y punto decimal)
' =============================================================================
Private Function RedondearStr(ByVal val As String) As String
    RedondearStr = val
    If Len(Trim(val)) = 0 Then Exit Function
    
    On Error Resume Next
    
    Dim s As String
    s = Trim(Replace(val, ",", "."))
    
    Dim posPunto As Long: posPunto = InStr(s, ".")
    If posPunto > 0 Then
        Dim parteEntera As Long
        Dim parteDecimal As String
        
        parteEntera = CLng(Left(s, posPunto - 1))
        parteDecimal = Mid(s, posPunto + 1, 1)
        
        If Len(parteDecimal) > 0 Then
            If CLng(parteDecimal) >= 5 Then parteEntera = parteEntera + 1
        End If
        
        RedondearStr = CStr(parteEntera)
    Else
        RedondearStr = CStr(CLng(s))
    End If
    
    If Err.Number <> 0 Then
        Err.Clear
        RedondearStr = val
    End If
    
    On Error GoTo 0
End Function

' =============================================================================
' HELPER: Abrir o reusar ensamble ya abierto en Inventor
' =============================================================================
Private Function AbrirObtenerEnsamble(ByVal filePath As String) As Object
    Set AbrirObtenerEnsamble = Nothing
    
    Dim d As Object
    For Each d In ThisApplication.Documents
        On Error Resume Next
        
        Dim fullName As String: fullName = d.FullFileName
        Dim docType As Long: docType = d.DocumentType
        
        If Err.Number = 0 Then
            If StrComp(fullName, filePath, vbTextCompare) = 0 And docType = 12291 Then
                Set AbrirObtenerEnsamble = d
                Exit Function
            End If
        End If
        
        Err.Clear
    Next d
    
    On Error Resume Next
    
    Dim opts As Object
    Set opts = ThisApplication.TransientObjects.CreateNameValueMap
    Set AbrirObtenerEnsamble = ThisApplication.Documents.OpenWithOptions(filePath, opts, False)
    
    If Err.Number <> 0 Then
        Debug.Print "No se pudo abrir: " & filePath & " - " & Err.Description
        Err.Clear
        Set AbrirObtenerEnsamble = Nothing
    End If
    
    On Error GoTo 0
End Function
